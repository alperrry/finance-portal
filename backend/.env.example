# =============================================
# Veritabanı Yapılandırması
# =============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/finance
SPRING_DATASOURCE_USERNAME=finance_user
SPRING_DATASOURCE_PASSWORD=

# =============================================
# Flyway & Hibernate
# =============================================
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=filesystem:/db/migrations
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# =============================================
# Redis Yapılandırması
# =============================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# =============================================
# Keycloak / OAuth2
# =============================================
KEYCLOAK_REALM=finance-portal
KEYCLOAK_ISSUER_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=http://fp-keycloak:8080
KEYCLOAK_ADMIN_CLIENT_ID=finance-portal-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=

# =============================================
# Groq AI
# =============================================
GROQ_API_KEY=
GROQ_API_MODEL=llama-3.3-70b-versatile
GROQ_API_TIMEOUT=30

# =============================================
# NewsAPI.org
# =============================================
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_COUNTRY=tr
NEWS_API_CATEGORY=business

# Haber çekici zamanlayıcı
NEWS_FETCHER_ENABLED=true
NEWS_FETCHER_FIXED_DELAY=300000
NEWS_FETCHER_INITIAL_DELAY=60000
NEWS_FETCHER_AI_MAX_CALLS_PER_RUN=30
NEWS_FETCHER_FILTER_NON_FINANCE=true

# =============================================
# TCMB (Türkiye Cumhuriyet Merkez Bankası)
# =============================================
TCMB_URL=https://www.tcmb.gov.tr/kurlar/today.xml
TCMB_ARCHIVE_URL=https://www.tcmb.gov.tr/kurlar/%s/%s.xml
TCMB_CRON=0 5 2 * * MON-SAT
TCMB_RETENTION_DAYS=365

# =============================================
# Hisse Senedi / Yahoo Finance
# =============================================
STOCK_QUOTE_URL=https://query1.finance.yahoo.com/v7/finance/quote?symbols=%s
STOCK_HISTORY_URL=https://query1.finance.yahoo.com/v8/finance/chart/%s?interval=1d&range=1y
YAHOO_CONSENT_URL=https://fc.yahoo.com
YAHOO_CRUMB_URL=https://query2.finance.yahoo.com/v1/test/getcrumb
MARKET_DAILY_STOCKS_CRON=0 0 2 * * MON-SAT
STOCK_INDICATOR_CRON=0 40 2 * * MON-SAT

# =============================================
# Fon Verileri (TEFAS)
# =============================================
FUND_BASE_URL=https://www.tefas.gov.tr
FUND_PORTAL_URL=https://www.tefas.gov.tr/tr/fon-verileri
FUND_HOME_URL=https://www.tefas.gov.tr/tr/fon-verileri
FUND_DAILY_CRON=0 10 2 * * MON-SAT
FUND_REQUEST_DELAY_MS=300
FUND_RETRY_DELAYS_MS=2000,5000,15000
FUND_INTER_FUND_BACKFILL_DELAY_MS=60000

# =============================================
# EVDS (Elektronik Veri Dağıtım Sistemi)
# =============================================
EVDS_BASE_URL=https://evds3.tcmb.gov.tr/igmevdsms-dis
EVDS_API_KEY=
EVDS_CRON=0 15 2 * * MON-SAT

# =============================================
# Makroekonomik Veri / Enflasyon
# =============================================
MACRO_DEPOSIT_CRON=0 20 2 * * MON-SAT
MACRO_INFLATION_CRON=0 25 2 * * *

# =============================================
# VIOP
# =============================================
VIOP_URL=https://www.isyatirim.com.tr/tr-tr/analiz/Sayfalar/viop.aspx
VIOP_CRON=0 30 2 * * MON-SAT

# =============================================
# HTTP İstemci Zaman Aşımları (saniye)
# =============================================
HTTP_CLIENT_CONNECT_TIMEOUT_SECONDS=10
HTTP_CLIENT_READ_TIMEOUT_SECONDS=10
HTTP_CLIENT_WRITE_TIMEOUT_SECONDS=10

# =============================================
# Uygulama Genel Ayarları
# =============================================
APP_STARTUP_TASKS_ENABLED=true
SWAGGER_UI_ENABLED=true
PORTFOLIO_VALUATION_CACHE_TTL=60
