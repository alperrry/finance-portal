{
  "realm": "finance-portal",
  "enabled": true,
  "displayName": "Finance Portal",
  "registrationAllowed": true,
  "rememberMe": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationEmailAsUsername": false,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "loginTheme": "finance-portal",
  "emailTheme": "finance-portal",
  "accountTheme": "keycloak.v2",
  "requiredCredentials": [
    "password"
  ],
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyInitialCounter": 0,
  "otpPolicyPeriod": 30,
  "roles": {
    "realm": [
      {
        "name": "NORMAL_USER",
        "description": "Default Finance Portal user role"
      },
      {
        "name": "ADMIN",
        "description": "Finance Portal administrator role"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-finance-portal",
    "description": "${role_default-roles}",
    "composite": true,
    "clientRole": false,
    "composites": {
      "realm": [
        "NORMAL_USER"
      ]
    }
  },
  "clients": [
    {
      "clientId": "finance-portal-frontend",
      "name": "Finance Portal Frontend",
      "description": "Public SPA client for the React frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:5173/*"
      }
    }
  ]
}
